# ═══════════════════════════════════════════════════════════════
# CRM Dra. Ilza — Variáveis de ambiente Firebase
# 
# 1. Copie este arquivo como .env.local  (desenvolvimento)
# 2. No Vercel: vá em Settings → Environment Variables → adicione cada uma
#
# Como obter:
#   https://console.firebase.google.com → Seu projeto →
#   Configurações (⚙️) → Seus apps → Web → firebaseConfig
# ═══════════════════════════════════════════════════════════════

VITE_FB_API_KEY=SUA_API_KEY
VITE_FB_AUTH_DOMAIN=SEU_PROJETO.firebaseapp.com
VITE_FB_DATABASE_URL=https://SEU_PROJETO-default-rtdb.firebaseio.com
VITE_FB_PROJECT_ID=SEU_PROJETO
VITE_FB_STORAGE_BUCKET=SEU_PROJETO.appspot.com
VITE_FB_MESSAGING_SENDER_ID=SEU_SENDER_ID
VITE_FB_APP_ID=SEU_APP_ID
